{
  "manifest_version": 3,
  "name": "Privacy Cleaner",
  "version": "1.0",
  "description": "One-click clear browsing data, cookies, and cache",
  "permissions": ["browsingData", "cookies", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon_128.png"
  }
}
