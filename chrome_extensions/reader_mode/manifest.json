{
  "manifest_version": 3,
  "name": "Reader Mode",
  "version": "1.0",
  "description": "Strip clutter and read any webpage in clean mode",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon_128.png"
  }
}
